# engine_service config — names only, never real values.
# In deployment these exist only in Cloud Run env (AD-12).

GEMINI_API_KEY=
ENGINE_SERVICE_SECRET=
GEMINI_MODEL_ID=

# Story 5.6 (AD-9) — per-Run interpretation ceiling / timeout / attempts.
# Non-secret; all have defaults so an engine-only deployment still boots.
# Bounded redraft attempts (calls ceiling). Default 3.
INTERPRETATION_MAX_ATTEMPTS=
# Per-Run cumulative token ceiling. Empty = unbounded.
INTERPRETATION_TOKEN_CEILING=
# Interpretation wall-clock timeout in seconds (NFR-7 ≤ 10 min). Default 600.
INTERPRETATION_TIMEOUT_SECONDS=
