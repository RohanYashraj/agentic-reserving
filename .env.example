# Product plane (Next.js / Convex / Clerk) — names only, never real values.
# Clerk keys live in Vercel + Convex env; engine secrets live in Cloud Run env only (AD-12).

# Convex (written to .env.local by `npx convex dev`)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Clerk (Story 1.2)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
# CLERK_JWT_ISSUER_DOMAIN is a Convex deployment env var, not a local one:
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN https://<your-app>.clerk.accounts.dev

# CLERK_WEBHOOK_SIGNING_SECRET (Story 1.4) is also a Convex deployment env var —
# the Svix signing secret for the Clerk → Convex webhook. Never in any .env file:
#   npx convex env set CLERK_WEBHOOK_SIGNING_SECRET whsec_...

# engine_service boundary (Story 3.2) — both are Convex deployment env vars, not
# local .env values. The browser never calls the engine; only Convex does (AD-12).
# ENGINE_SERVICE_URL is the engine base URL; ENGINE_SERVICE_SECRET is the shared
# bearer secret, mirroring the value in the engine's Cloud Run env (engine/.env.example):
#   npx convex env set ENGINE_SERVICE_URL https://<engine-host>
#   npx convex env set ENGINE_SERVICE_SECRET <same-secret-as-cloud-run>
